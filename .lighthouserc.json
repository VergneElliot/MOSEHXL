{
  "ci": {
    "collect": {
      "url": ["http://localhost:3000"],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.4 }],
        "categories:accessibility": ["warn", { "minScore": 0.4 }],
        "categories:best-practices": ["warn", { "minScore": 0.4 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
