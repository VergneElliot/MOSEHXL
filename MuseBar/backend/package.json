{
  "name": "mosehxl-backend",
  "version": "1.0.0",
  "description": "MOSEHXL - Point of Sale & Bar Management System Backend API",
  "main": "dist/app.js",
  "author": "Elliot Vergne <elliot.vergne@gmail.com>",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:real-db": "RUN_REAL_DB_TESTS=true vitest run --project real-db",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "dev": "ts-node src/app.ts",
    "build": "tsc && mkdir -p dist/docs dist/migrations/files && cp src/docs/openapi.yaml dist/docs/ && cp src/migrations/files/*.sql dist/migrations/files/",
    "start": "node dist/app.js",
    "check:schema-drift": "node scripts/check-legal-schema-drift.js",
    "migration:migrate": "ts-node src/migrations/cli.ts migrate",
    "migration:rollback": "ts-node src/migrations/cli.ts rollback",
    "migration:status": "ts-node src/migrations/cli.ts status",
    "migration:create": "ts-node src/migrations/cli.ts create"
  },
  "keywords": [
    "pos",
    "restaurant",
    "bar",
    "legal-compliance",
    "point-of-sale"
  ],
  "license": "PROPRIETARY",
  "dependencies": {
    "@mosehxl/types": "file:../packages/types",
    "@sendgrid/mail": "^8.1.5",
    "@types/express": "^4.17.23",
    "@types/speakeasy": "^2.0.10",
    "@types/yamljs": "^0.2.34",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.5.48",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.10",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.15.4",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
