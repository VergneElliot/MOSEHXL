# Copy to `.env` and fill in real values (no defaults for secrets).

# Node / environment
NODE_ENV=

# Database
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Security
JWT_SECRET=

# Security (protects one-time bootstrap endpoints like /api/auth/setup)
SETUP_SECRET=

# Security (required in production for legal/archive signing)
ARCHIVE_SECRET_KEY=

# CORS
CORS_ORIGIN=

# Optional (use defaults if omitted)
PORT=
HOST=
DB_MAX_CONNECTIONS=
DB_IDLE_TIMEOUT=
# Production default is secure (`true`). Set one of these only if your provider
# requires self-signed acceptance.
DB_SSL_REJECT_UNAUTHORIZED=
DB_SSL_ALLOW_SELF_SIGNED=
BCRYPT_ROUNDS=
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_REQUESTS=
# Optional HIBP k-anonymity password breach check (P3-S7)
PASSWORD_BREACH_CHECK_ENABLED=
PASSWORD_BREACH_CHECK_TIMEOUT_MS=
# Enforce TOTP for admin roles (`system_admin`, `establishment_admin`)
# Defaults to true in production and false in non-production when omitted.
AUTH_ENFORCE_ADMIN_2FA=
# JWT signing mode (`HS256` default, `RS256` for asymmetric production mode)
AUTH_JWT_SIGN_ALG=
# In RS256 mode, key id used in JWT header (`kid`) for active signing key
AUTH_JWT_KID=
# RS256 signing private key (PEM)
JWT_PRIVATE_KEY=
# RS256 active public key (PEM)
JWT_PUBLIC_KEY=
# Optional JSON object for additional RS256 verify-only public keys during rotation
# Example: {"mosehxl-rs256-2026-05":"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"}
AUTH_JWT_ADDITIONAL_PUBLIC_KEYS_JSON=
# Optional migration override. In RS256 production mode defaults to false when omitted.
AUTH_JWT_ALLOW_LEGACY_HS256_VERIFY=
# Reject JWTs that still carry retired legacy `is_admin` claim.
# Defaults to true in production and false outside production when omitted.
AUTH_REJECT_LEGACY_IS_ADMIN_CLAIM=
# Cashier-friendly session defaults. Access tokens stay in memory; refresh cookies rotate server-side.
# Defaults: access token 12h, normal refresh 1 day, "Rester connecte" refresh 30 days, absolute cap 180 days.
AUTH_ACCESS_TOKEN_EXPIRES_IN=
AUTH_REFRESH_SESSION_DAYS=
AUTH_REFRESH_REMEMBER_DAYS=
AUTH_REFRESH_ABSOLUTE_MAX_DAYS=
# Permission fallback mode for `establishment_admin` role.
# Defaults to `explicit_only` in production and `implicit_all` outside production.
ESTABLISHMENT_ADMIN_PERMISSION_MODE=

# Optional features (email)
SENDGRID_API_KEY=
FROM_EMAIL=
# Public base URL for Epson poll links and document emails (e.g. https://mosehxl.com)
APP_URL=
PUBLIC_API_URL=

# LAN receipt printer fallback (network-escpos provider). Backend must be on same network.
THERMAL_PRINTER_HOST=
THERMAL_PRINTER_PORT=9100

# Optional features (legal journal)
LEGAL_JOURNAL_ENABLED=
AUTO_CLOSURE_ENABLED=
SWAGGER_ENABLED=
LOG_LEVEL=
ENABLE_FILE_LOGGING=
ENABLE_DB_LOGGING=

