{
  "name": "musebar-print-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Local MuseBar print bridge for network ESC/POS printers",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "bridge": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "test": "npm run build && node --test test/*.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.0.7",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.29.0",
    "typescript": "^5.8.3"
  }
}
